# =============================================================================
# KALSHI BOT ‚Äî ENVIRONMENT VARIABLES (canonical reference)
# =============================================================================
# Copy to `.env` and edit. The app loads `.env` only (this file is documentation).
#
#   cp .env.example .env
#
# Naming: TRADE_* = execution; risk keys = bankroll / session stops. Legacy aliases
# (STRATEGY_*, AUTO_SELL_*, etc.) still work ‚Äî see `config.py` AliasChoices.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_PRIVATE_KEY_PEM=
KALSHI_ENV=demo

# KALSHI_REST_BASE_URL=
# KALSHI_WS_URL=

# -----------------------------------------------------------------------------
# Safety ‚Äî simulation vs live exchange
# -----------------------------------------------------------------------------
LIVE_TRADING=false
DRY_RUN=true

# -----------------------------------------------------------------------------
# Risk & bankroll ‚Äî how much you can lose / hold
# -----------------------------------------------------------------------------
# Max marked exposure (cents) when TRADE_BALANCE_SIZING_ENABLED=false or balance unavailable.
# With balance sizing + live balance, cap is balance√óTRADE_TOTAL_RISK_PCT_OF_BALANCE instead.
MAX_EXPOSURE_CENTS=50000

# Max net YES shares per market (Kalshi: contracts). Alias: TRADE_MAX_SHARES_PER_MARKET. Clamped 1‚Äì99 in code.
# With balance sizing + balance, per-order cap is balance√óTRADE_RISK_PCT_OF_BALANCE_PER_TRADE√∑YES price.
MAX_CONTRACTS_PER_MARKET=5

# Session stop: no new risk after this drawdown vs session start balance (USD).
# TRADE_STOP_MAX_SESSION_LOSS_USD = alias for MAX_DAILY_DRAWDOWN_USD.
MAX_DAILY_DRAWDOWN_USD=25

MAX_OPEN_ORDERS_PER_MARKET=3
STALE_ORDER_SECONDS=3600

# -----------------------------------------------------------------------------
# Risk ‚Äî cooldowns & kill switch
# -----------------------------------------------------------------------------
COOLDOWN_AFTER_LOSS_SECONDS=0
LOSS_STREAK_THRESHOLD=3
COOLDOWN_AFTER_LOSS_STREAK_SECONDS=0
NO_MARTINGALE=true
KILL_SWITCH=false

# =============================================================================
# TRADING ‚Äî one market, entry (buy), exit (take profit), pacing
# =============================================================================

# --- Market (sample `run` strategy + default ticker for CLI helpers) ---
TRADE_MARKET_TICKER=

# --- Entry: buy YES when the book looks cheap enough & not a coin-flip ---
# Max YES **ask** you will pay, as a fraction of $1 (0‚Äì1 only). Higher = more trades (more expensive names).
TRADE_BUY_MAX_YES_ASK_DOLLARS=0.90
# Hard ceiling (¬¢): effective max ask = min(TRADE_BUY_MAX_YES_ASK_DOLLARS, this/100). Default 90 = no entries above 90¬¢.
TRADE_ENTRY_HARD_MAX_YES_ASK_CENTS=90

# Limit price for that buy, in **cents** (1‚Äì99 on the YES contract).
TRADE_BUY_LIMIT_YES_PRICE_CENTS=78

# Default shares per buy for discover/tape/bitcoin (Kalshi: contracts). Alias: TRADE_BUY_SHARES_PER_ORDER. Clamped 1‚Äì99.
# llm-trade ignores this for sizing ‚Äî the model returns `shares` (1..MAX_CONTRACTS_PER_MARKET) from edge/profit judgment.
TRADE_BUY_CONTRACTS_PER_ORDER=5

# Per-order USD at limit: floor always from MIN. MAX used when TRADE_BALANCE_SIZING_ENABLED=false or balance unknown;
# with balance sizing, per-order $ cap is balance√óTRADE_RISK_PCT_OF_BALANCE_PER_TRADE (same as contract budget).
TRADE_MIN_ORDER_NOTIONAL_USD=0
TRADE_MAX_ORDER_NOTIONAL_USD=10
# Optional: rotate cap $ per order (does not set a minimum; min is only TRADE_MIN_ORDER_NOTIONAL_USD). Clear to disable.
TRADE_NOTIONAL_SWEEP_USD=1,3,5,7,10
# Seconds to wait after each submitted buy YES (dry-run or live). 0 = no pause.
TRADE_SUBMIT_SPACING_SECONDS=5

# Min bid‚Äìask spread (0‚Äì1 on $1). 0 = never block on spread width.
TRADE_ENTRY_MIN_SPREAD_DOLLARS=0

# ‚ÄúPercentage / edge‚Äù filter: require |mid ‚àí 50%| ‚â• this (same 0‚Äì1 scale as prices).
# 0 = allow coin-flip mids (more signals). 0.02 ‚âà skip ~48‚Äì52¬¢ band.
TRADE_ENTRY_MIN_EDGE_FROM_50=0
# Minimum implied YES (‚Äúchance‚Äù on Kalshi = this as %% on $1, e.g. 45 = 45¬¢). Stops ~1%% long-shot entries.
# Alias: TRADE_ENTRY_MIN_YES_CHANCE_PCT. Use 0 only for raw flow/tape with no probability floor.
TRADE_ENTRY_MIN_YES_ASK_CENTS=45
# If >0: skip buy YES when implied American long odds exceed this (+200 ‚âà 34¬¢ min implied). 0 = off.
TRADE_ENTRY_MAX_AMERICAN_ODDS_YES=200
# Comma-separated substrings: skip buy YES when the market ticker contains any token (case-insensitive). Example: MASTERS,PGA
# TRADE_ENTRY_SKIP_TICKER_SUBSTRINGS=
# Limit ‚Äúmany long-shot legs‚Äù in one event family: skip new buys when you already hold long YES in N distinct tickers matching substring.
# Example: TRADE_ENTRY_CAP_LONG_YES_SUBSTRING=MASTERS and TRADE_ENTRY_CAP_LONG_YES_MAX=3
# TRADE_ENTRY_CAP_LONG_YES_SUBSTRING=
# TRADE_ENTRY_CAP_LONG_YES_MAX=0
# Theta: skip long-shot YES (¬¢ band) near resolution ‚Äî options-style time decay (default max window 1h)
# TRADE_ENTRY_THETA_DECAY_ENABLED=true
# TRADE_ENTRY_THETA_SECONDS_TO_CLOSE_MAX=3600
# TRADE_ENTRY_THETA_MIN_YES_ASK_CENTS=1
# TRADE_ENTRY_THETA_MAX_YES_ASK_CENTS=10
# Only top-N by implied YES within same event (e.g. golf favorites) ‚Äî substring filters which tickers use this rule
# TRADE_ENTRY_EVENT_TOP_N=0
# TRADE_ENTRY_EVENT_TOP_N_SUBSTRING=
# Auto binary vs multi-choice: 2+ open markets per event = multi (top-3 + min chance); 1 = binary (uses TRADE_ENTRY_MIN_YES_* only)
# TRADE_ENTRY_MARKET_INTELLIGENCE_ENABLED=true
# TRADE_ENTRY_MULTI_CHOICE_TOP_N=3
# TRADE_ENTRY_MULTI_CHOICE_MIN_YES_ASK_CENTS=50
# Only trade markets whose soonest resolution is within this many seconds (skip if farther). 12h=43200. 0=off. Unknown times are not skipped.
# TRADE_ENTRY_MAX_SECONDS_UNTIL_RESOLUTION=43200
# Compare YES vs NO lift; score each leg (ask¬¢ ‚àí penalty√óspread¬¢) and take the better line. 0 = ask-only (ignore spread).
TRADE_ENTRY_PREFER_HIGHER_ODDS_SIDE_ENABLED=true
TRADE_ENTRY_SIDE_CHOICE_SPREAD_PENALTY=0.5

# --- Edge-aware entry (fee-adjusted mispricing vs your fair value) ---
# Set TRADE_USE_EDGE_STRATEGY=true and TRADE_FAIR_YES_PROB=0.0‚Äì1.0 to buy YES only when
# (fair ‚àí YES_ask ‚àí taker fee) clears TRADE_MIN_NET_EDGE_AFTER_FEES, with extra hurdle near 50%.
# Values are on the $1 contract face (0‚Äì1). Lower = more fills through the edge gate.
# TRADE_USE_EDGE_STRATEGY=false
# TRADE_FAIR_YES_PROB=
# Base min edge for edge-strategy + LLM (unless TRADE_LLM_MIN_NET_EDGE_AFTER_FEES overrides).
TRADE_MIN_NET_EDGE_AFTER_FEES=0.002
# Extra edge required near 50¬¢ mid (fee-aware paths). 0 = off.
TRADE_EDGE_MIDDLE_EXTRA_EDGE=0.003
# llm-trade only: 0 = no extra mid hurdle for LLM path (more fills). Omit to inherit TRADE_EDGE_MIDDLE_EXTRA_EDGE.
TRADE_LLM_EDGE_MIDDLE_EXTRA_EDGE=0
# TRADE_LLM_MIN_NET_EDGE_AFTER_FEES=

# `kalshi-bot scan` ‚Äî optional OpenAI fair value for titles (costs API $; not advice)
# TRADE_LLM_SCREEN_ENABLED=false
# OPENAI_API_KEY=
# Small GPT-5-class (Chat Completions): gpt-5.4-mini | gpt-5.4-nano (cheaper) | gpt-5-nano (legacy). Use gpt-4o-mini if your key cannot access GPT-5.
TRADE_LLM_MODEL=gpt-5.4-mini

# `kalshi-bot llm-trade` ‚Äî market universe
# Production "live" markets: set KALSHI_ENV=prod (not demo). The Kalshi website "Live" tab is UI-curated; this bot
# has no identical API flag. Closest match for "where trading is active right now": rank by **public trade tape**
# (`kalshi-bot llm-trade --tape` or TRADE_LLM_USE_TAPE_UNIVERSE=true + TRADE_TAPE_* below).
# Tape mode ranks markets by anonymous public $ flow; each LLM prompt includes flow + rank for opportunity context.
# TRADE_LLM_USE_TAPE_UNIVERSE=false
# `kalshi-bot llm-trade` / `discover-trade` ‚Äî open markets per pass (up to 2000 in code)
TRADE_LLM_MAX_MARKETS_PER_RUN=900
# llm-trade paginates get_markets until it has this many *distinct* tickers (not one sparse page)
TRADE_LLM_OPEN_MARKETS_MAX_PAGES=100
# Skip 0..N list_markets pages before sampling so each run pulls a different slice + shuffle = fresher tickers
TRADE_LLM_RANDOM_SKIP_PAGES_MAX=35
# Prepend KXBTC (volume-sorted) then fill from the general open walk (deduped). Default off.
TRADE_LLM_BITCOIN_PRIORITY_ENABLED=false
TRADE_LLM_BITCOIN_PRIORITY_PREFIX=KXBTC
TRADE_LLM_BITCOIN_PRIORITY_MAX_MARKETS=150
# Randomize order each run so stable API ordering does not always prioritize the same contracts
TRADE_LLM_SHUFFLE_OPEN_MARKETS=true
# Optional: REST volume must be ‚â• this (skips illiquid; omit to disable)
# TRADE_MIN_MARKET_VOLUME=
# Max YES bid‚Äìask spread ‚Äî omit or comment out for no ceiling (widest books allowed).
# TRADE_MAX_ENTRY_SPREAD_DOLLARS=0.48

# `kalshi-bot llm-trade` ‚Äî LLM scans markets; code re-checks fee-edge vs your limits
# Use `kalshi-bot llm-trade --tape` to rank tape by flow first (uses TRADE_TAPE_*), then LLM.
# If true, llm-trade submits without CLI --execute (still needs TRADE_LLM_AUTO_EXECUTE=true)
# TRADE_LLM_CLI_EXECUTE=false
# Must be true to actually send orders with: kalshi-bot llm-trade --execute (or TRADE_LLM_CLI_EXECUTE=true)
# TRADE_LLM_AUTO_EXECUTE=false
# Softer LLM instructions (more approvals when true).
TRADE_LLM_RELAXED_APPROVAL=true
# If true: when LLM declines but fair is near ask, still run deterministic edge checks.
TRADE_LLM_ACCEPT_WHEN_FAIR_COVERS_ASK=true
TRADE_LLM_FAIR_ASK_SLIPPAGE=0.04

# Tighten fee-edge + LLM prompt when dashboard W‚ÄìL skews negative. false = do not auto-tighten after losses.
TRADE_LLM_ADAPT_TO_SESSION_WL=false
TRADE_LLM_ADAPT_MIN_CLOSED_TRADES=5

# `kalshi-bot discover-trade` ‚Äî LLM only filters which titles to consider; buys use TRADE_BUY_* / edge from .env
# Optional: e.g. "only professional sports moneylines" ‚Äî empty = LLM allows normal prediction markets
# TRADE_LLM_DISCOVERY_QUERY=
# Must be true to send orders with: kalshi-bot discover-trade --execute
# TRADE_DISCOVER_AUTO_EXECUTE=false

# `kalshi-bot tape-trade` ‚Äî rank markets by **anonymous** public trade $ flow (also used by `llm-trade --tape`)
TRADE_TAPE_MAX_TRADES_FETCH=3000
TRADE_TAPE_TOP_MARKETS=200
TRADE_TAPE_MIN_FLOW_USD=0
# TRADE_TAPE_AUTO_EXECUTE=false

# `kalshi-bot bitcoin-trade` ‚Äî public BTC/ETH spot ref + Kalshi crypto binaries (same rules as tape-trade).
# Pin one contract, OR set comma-separated prefixes to discover (union). If both empty and no pin, default discovery uses KXBTC.
# TRADE_CRYPTO_KALSHI_PREFIXES=KXBTC
# Reference spot: auto | coingecko | binance (KXETH* tickers use ETH/USD).
# TRADE_CRYPTO_SPOT_PRICE_SOURCE=auto
# TRADE_BITCOIN_KALSHI_TICKER=
# Legacy single-prefix discovery when TRADE_CRYPTO_KALSHI_PREFIXES is empty:
# TRADE_BITCOIN_TICKER_PREFIX=
# TRADE_BITCOIN_MAX_UNIVERSE=80
# TRADE_BITCOIN_DISCOVERY_MAX_PAGES=40
# TRADE_BITCOIN_AUTO_EXECUTE=false
# During tape-trade / discover-trade: run crypto logic every N ticker scans (rotation + prefix discovery; shared counters)
# TRADE_BITCOIN_SIDECAR_ENABLED=false
# TRADE_BITCOIN_EVERY_N_TICKER_SCANS=50
# Second terminal (alongside llm-trade): `kalshi-bot bitcoin-trade --execute --loop` ‚Äî avoid two --web on port 5050 unless you set DASHBOARD_PORT.

# Chart momentum (REST candlesticks): buy YES when recent YES *trade* price is rising quickly ‚Äî tape/discover
# try this before spread/edge rules. Optional: `llm-trade` skips the LLM when TRADE_MOMENTUM_LLM_BYPASS=true.
# TRADE_MOMENTUM_ENABLED=false
# TRADE_MOMENTUM_PERIOD_MINUTES=5
# TRADE_MOMENTUM_LOOKBACK_MINUTES=120
# TRADE_MOMENTUM_MIN_CANDLES=4
# TRADE_MOMENTUM_SHORT_CANDLES=6
# TRADE_MOMENTUM_MIN_NET_RISE_DOLLARS=0.015
# TRADE_MOMENTUM_MIN_RISE_PER_CANDLE_DOLLARS=0.002
# TRADE_MOMENTUM_LLM_BYPASS=false

# Add-on YES (double-down) ‚Äî llm-trade only: buy more YES when already long if LLM + fee-edge still pass.
# When TRADE_DOUBLE_DOWN_ENABLED=true, momentum LLM bypass is skipped while you hold YES so add-ons go through the LLM.
# TRADE_DOUBLE_DOWN_ENABLED=false
# TRADE_DOUBLE_DOWN_MAX_POSITION_CONTRACTS=5
# TRADE_DOUBLE_DOWN_EXTRA_MIN_NET_EDGE_AFTER_FEES=0

# Spike fade (llm-trade): recent YES candle rise ‚Üí tighter edge for buy YES unless net edge is ‚Äúhuge‚Äù; also disables momentum LLM bypass on that ticker.
# TRADE_SPIKE_FADE_ENABLED=false
# TRADE_SPIKE_FADE_PERIOD_INTERVAL_MINUTES=5
# TRADE_SPIKE_FADE_LOOKBACK_MINUTES=120
# TRADE_SPIKE_FADE_MIN_CANDLES=4
# TRADE_SPIKE_FADE_SHORT_CANDLES=6
# TRADE_SPIKE_FADE_MIN_NET_RISE_DOLLARS=0.025
# TRADE_SPIKE_FADE_EXTRA_MIN_NET_EDGE_AFTER_FEES=0.03
# TRADE_SPIKE_FADE_HUGE_NET_EDGE_AFTER_FEES=0.10

# Scale exposure, per-order contracts, and per-order $ cap from account balance (percent of balance).
TRADE_BALANCE_SIZING_ENABLED=true
# Per-trade budget (fraction of balance): drives max shares at a given YES price and max order $ at limit.
TRADE_RISK_PCT_OF_BALANCE_PER_TRADE=0.04
# Total marked exposure cap ‚âà balance √ó this (replaces MAX_EXPOSURE_CENTS when sizing is on and balance is known).
TRADE_TOTAL_RISK_PCT_OF_BALANCE=0.25
# If true: no portfolio exposure dollar cap (until API reports balance‚â§0). Ignores TRADE_TOTAL_RISK_PCT_OF_BALANCE for that cap.
# TRADE_NO_MAX_EXPOSURE_CAP=false

# --- Exit (`kalshi-bot auto-sell`) ‚Äî implied % OR profit margin; fast IOC-style sells ---
# Kalshi supports time_in_force: immediate_or_cancel (IOC), fill_or_kill, good_till_canceled.
# Default IOC avoids resting exit orders (see API docs). Aggression: sell at best_bid minus N cents.

# After each llm-trade / discover-trade / tape-trade pass, scan all long YES and try take-profit (same rules).
TRADE_AUTO_SELL_AFTER_EACH_PASS=true

# Before that exit scan: print book + per-ticker tape lean (like `positions-watch`, no second terminal).
TRADE_POSITION_WATCH_BEFORE_AUTO_SELL=true

# Split processes: trade bot = scan + entries only; separate terminal = exits only.
# TRADE_AUTO_SELL_AFTER_EACH_PASS=false
# Then run: kalshi-bot sell-bot   (same as exit-scan --loop --execute; optional --web for dashboard)
# SELL_BOT_INTERVAL_SECONDS=30

# Optional: if recent public tape is NO-heavy (taker YES share ‚â§ TRADE_EXIT_TAPE_NO_HEAVY_MAX_YES_SHARE), lower
# min-profit take-profit by TRADE_EXIT_TAPE_NO_HEAVY_RELAX_MIN_PROFIT_CENTS. 0 = tape does not change exit math.
# TRADE_EXIT_TAPE_NO_HEAVY_RELAX_MIN_PROFIT_CENTS=0
# TRADE_EXIT_TAPE_NO_HEAVY_MAX_YES_SHARE=0.38
# TRADE_EXIT_TAPE_MIN_TRADES_FOR_EXIT=8
# TRADE_EXIT_TAPE_LOOKBACK_MAX_TRADES=150

# If implied YES ‚Äúchance‚Äù (mid of best bid and lift YES ask) ‚â• this (1‚Äì99), skip exits and hold for final payout. 0 = off.
TRADE_EXIT_HOLD_TO_SETTLEMENT_MIN_CHANCE_CENTS=90
# If implied chance is within N cents of 100¬¢ (e.g. 2 ‚Üí ‚â•98¬¢), do not hold for settlement‚Äîsell (take-profit near max). 0 = off.
TRADE_EXIT_SELL_WITHIN_CENTS_OF_MAX_PAYOUT=2

# Implied YES chance ‚â• this = full-payout territory (use normal TRADE_EXIT_MIN_PROFIT_*). Below: TP at entry + next line (¬¢/share).
TRADE_EXIT_FULL_PAYOUT_INDICATION_MIN_CHANCE_CENTS=90
TRADE_EXIT_MIN_PROFIT_CENTS_NO_FULL_PAYOUT_INDICATION=5

# When TRADE_EXIT_ONLY_PROFIT_MARGIN=false: take profit when best YES bid ‚â• this (1‚Äì99 implied %).
TRADE_EXIT_TAKE_PROFIT_MIN_YES_BID_PCT=72

# Optional explicit floor in cents (overrides the % default above when set).
# TRADE_TAKE_PROFIT_MIN_YES_BID_CENTS=85

# Floor: min ¬¢/share profit vs entry. With PCT/CAP below, effective = max(floor, entry√ópct), then min(..., cap).
TRADE_EXIT_MIN_PROFIT_CENTS_PER_CONTRACT=15
# Fraction of entry (0‚Äì1): e.g. 0.25 = require 25% of entry in ¬¢ as profit (scales with cheap vs expensive names).
TRADE_EXIT_MIN_PROFIT_PCT_OF_ENTRY=0.25
# When >1: take-profit when best bid ‚â• ceil(entry√óthis), e.g. 1.5 ‚Üí 50¬¢ entry sells at ‚â•75¬¢ (+50% vs entry). Bypasses hold-to-settlement. 0 or 1 = off.
TRADE_EXIT_TAKE_PROFIT_MIN_BID_VS_ENTRY_MULTIPLIER=1.5
# Optional ceiling (¬¢) on required min profit (omit or empty for no cap).
TRADE_EXIT_MIN_PROFIT_CENTS_CAP=25
# Once peak bid reaches entry + this (¬¢), never exit below entry + this (merged with trailing pullback).
TRADE_EXIT_LOCK_PROFIT_CENTS=15

# Manual average entry (cents) for profit math; if unset, estimate from portfolio (rough).
# Strongly recommended when you care about exact exit P/L: TRADE_EXIT_ENTRY_REFERENCE_YES_CENTS=
TRADE_EXIT_ESTIMATE_ENTRY_FROM_PORTFOLIO=true

# true = profit-margin exits only (skip implied-% TP): sell when bid ‚â• entry + min profit above.
TRADE_EXIT_ONLY_PROFIT_MARGIN=true

# Stop-loss (long YES): sell when best bid ‚â§ round(entry¬¢ √ó fraction). 0.5 ‚âà ‚Äú50% of entry price‚Äù in cents.
TRADE_EXIT_STOP_LOSS_ENABLED=true
# Long YES stop: sell when best bid ‚â§ round(entry_cents √ó this). 0.8 = stop at 80% of entry ¬¢ (50¬¢ entry ‚Üí 40¬¢ floor).
TRADE_EXIT_STOP_LOSS_ENTRY_FRACTION=0.8
# If true (default), do not use portfolio entry estimates ‚â§5¬¢ or ‚â•95¬¢ for stop-loss (often bad averages).
TRADE_EXIT_STOP_LOSS_SKIP_SUSPECT_PORTFOLIO_ESTIMATE=true

# Trailing stop after price trends up vs entry (session peak best YES bid; in-process only).
TRADE_EXIT_TRAILING_ENABLED=true
# Exit when bid drops this many ¬¢ below peak (after arms). Optional: TRADE_EXIT_TRAILING_PULLBACK_PCT_OF_PEAK.
TRADE_EXIT_TRAILING_PULLBACK_CENTS=4
TRADE_EXIT_TRAILING_PULLBACK_PCT_OF_PEAK=0
# Require peak ‚â• entry + this (¬¢) before trailing / raised stop applies.
TRADE_EXIT_TRAILING_ACTIVATE_ABOVE_ENTRY_CENTS=1
# Combine peak‚àípullback with fraction stop. true = min(peak‚àípullback, best_bid√ófraction) so the stop moves down when price falls; false = legacy max(entry√ófraction, peak‚àípullback).
TRADE_EXIT_TRAILING_COMBINE_WITH_FIXED_STOP=true
TRADE_EXIT_TRAILING_BID_FRACTION_CAPS_PEAK_TRAIL=true
# When armed: use max(TRADE_EXIT_STOP_LOSS_ENTRY_FRACTION, this) for the effective fraction vs bid (and vs entry when legacy combine).
TRADE_EXIT_TRAILING_STOP_LOSS_FLOOR_FRACTION=0.58

TRADE_EXIT_SELL_TIME_IN_FORCE=immediate_or_cancel
TRADE_EXIT_SELL_AGGRESSION_CENTS=0

# After a stop-loss (fixed stop): optionally buy YES again on the same ticker (TRADE_BUY_* gates; risk/exposure still apply).
# TRADE_REBUY_AFTER_STOP_LOSS_ENABLED=false
# TRADE_REBUY_AFTER_STOP_LOSS_INCLUDE_TRAILING_AND_PROFIT_LOCK=false
# TRADE_REBUY_AFTER_STOP_LOSS_DELAY_SECONDS=0
# TRADE_REBUY_AFTER_STOP_LOSS_COOLDOWN_SECONDS=5
# TRADE_REBUY_AFTER_STOP_LOSS_TIME_IN_FORCE=immediate_or_cancel

# How often to poll the book for auto-sell (seconds).
TRADE_TAKE_PROFIT_POLL_SECONDS=2

# --- Pacing: WebSocket `run` only ‚Äî min seconds between signals (0 = off). Entry spacing uses TRADE_SUBMIT_SPACING_SECONDS.
TRADE_MIN_SECONDS_BETWEEN_ORDERS=0

# -----------------------------------------------------------------------------
# Paper / backtest (simulated fills)
# -----------------------------------------------------------------------------
PAPER_FEE_CENTS_PER_CONTRACT=0
PAPER_SLIPPAGE_CENTS_PER_CONTRACT=0
PAPER_FILL_PROBABILITY=0.85

# -----------------------------------------------------------------------------
# Local dashboard (`kalshi-bot run`, `--web` on trade commands)
# -----------------------------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050
DASHBOARD_OPEN_BROWSER=true
# POST auto-sell / exit-scan sells to the local dashboard so W‚ÄìL and events update from a separate terminal.
DASHBOARD_INGEST_AUTO_SELL=true
# POST order/trade rows (dry-run, live, blocked, ‚Ä¶) to the dashboard Trades & orders feed when the bot runs without --web or in another process.
DASHBOARD_INGEST_TRADE_EVENTS=true
# After each llm/discover/tape/bitcoin pass, POST to the dashboard so it appends a portfolio chart point when the trade process does not embed the Flask server (no --web). Dashboard must share the same .env API keys.
DASHBOARD_INGEST_PORTFOLIO_SERIES=true
# Balance/exposure chart: poll API this often during long llm-trade / tape / discover passes (seconds). 0 = chart points only at start/end of each pass.
DASHBOARD_PORTFOLIO_POLL_SECONDS=20

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
STRUCTURED_LOG_PATH=logs/kalshi_bot.jsonl
# Fee-aware break-even vs your auto-sell closes: `kalshi-bot exit-expectancy` (reads this JSONL).
# Per-ticker (inside one scan): truncate JSONL every N tickers. 0 = never (use pass-level clear when looping).
STRUCTURED_LOG_CLEAR_EVERY_N_TICKERS=0
# llm/discover/tape/bitcoin-trade with --loop: truncate JSONL after every 2nd completed pass (2, 4, 6‚Ä¶).
STRUCTURED_LOG_CLEAR_EVERY_OTHER_PASS=true

# -----------------------------------------------------------------------------
# GitHub (optional ‚Äî not read by kalshi-bot)
# Paste a classic or fine-grained PAT for HTTPS push / gh. Keep `.env` untracked.
# Example: git remote set-url origin https://${GITHUB_TOKEN}@github.com/chacegarcia/kalshi-app.git
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# SSH for git@github.com (optional ‚Äî not read by kalshi-bot)
# Preferred: path to your *private* key file. Public key ‚Üí GitHub ‚Üí Settings ‚Üí SSH and GPG keys.
# GIT_SSH_COMMAND="ssh -i $GITHUB_SSH_PRIVATE_KEY_PATH -o IdentitiesOnly=yes" git push
# Example if you keep keys in repo root (still gitignored): ./ghkey-kalshi ‚Äî use absolute path for ssh -i if needed.
# -----------------------------------------------------------------------------
GITHUB_SSH_PRIVATE_KEY_PATH=
# Optional one-line base64 of the PEM (decode to a temp file before git): base64 -i ~/.ssh/id_ed25519
# GITHUB_SSH_PRIVATE_KEY_B64=
