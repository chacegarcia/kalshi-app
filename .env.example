# =============================================================================
# KALSHI BOT — ENVIRONMENT VARIABLES (canonical reference)
# =============================================================================
# Copy to `.env` and edit. The app loads `.env` only (this file is documentation).
#
#   cp .env.example .env
#
# Naming: TRADE_* = execution; risk keys = bankroll / session stops. Legacy aliases
# (STRATEGY_*, AUTO_SELL_*, etc.) still work — see `config.py` AliasChoices.
# =============================================================================

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_PRIVATE_KEY_PEM=
KALSHI_ENV=demo

# KALSHI_REST_BASE_URL=
# KALSHI_WS_URL=

# -----------------------------------------------------------------------------
# Safety — simulation vs live exchange
# -----------------------------------------------------------------------------
LIVE_TRADING=false
DRY_RUN=true

# -----------------------------------------------------------------------------
# Risk & bankroll — how much you can lose / hold
# -----------------------------------------------------------------------------
# Max marked exposure across all positions (cents). TRADE_MAX_TOTAL_EXPOSURE_CENTS = alias.
MAX_EXPOSURE_CENTS=50000

# Max net contracts per market (position + working orders). TRADE_MAX_CONTRACTS_PER_MARKET = alias.
MAX_CONTRACTS_PER_MARKET=10

# Session stop: no new risk after this drawdown vs session start balance (USD).
# TRADE_STOP_MAX_SESSION_LOSS_USD = alias for MAX_DAILY_DRAWDOWN_USD.
MAX_DAILY_DRAWDOWN_USD=25

MAX_OPEN_ORDERS_PER_MARKET=3
STALE_ORDER_SECONDS=3600

# -----------------------------------------------------------------------------
# Risk — cooldowns & kill switch
# -----------------------------------------------------------------------------
COOLDOWN_AFTER_LOSS_SECONDS=300
LOSS_STREAK_THRESHOLD=3
COOLDOWN_AFTER_LOSS_STREAK_SECONDS=900
NO_MARTINGALE=true
KILL_SWITCH=false

# =============================================================================
# TRADING — one market, entry (buy), exit (take profit), pacing
# =============================================================================

# --- Market (sample `run` strategy + default ticker for CLI helpers) ---
TRADE_MARKET_TICKER=

# --- Entry: buy YES when the book looks cheap enough & not a coin-flip ---
# Max YES **ask** you will pay, in dollars on 0–1 scale (0.55 ≈ 55% implied probability).
TRADE_BUY_MAX_YES_ASK_DOLLARS=0.55

# Limit price for that buy, in **cents** (1–99 on the YES contract).
TRADE_BUY_LIMIT_YES_PRICE_CENTS=50

# Contracts per buy signal.
TRADE_BUY_CONTRACTS_PER_ORDER=1

# Require at least this bid–ask spread (dollars) before buying.
TRADE_ENTRY_MIN_SPREAD_DOLLARS=0.00

# “Percentage / edge” filter: require |mid − 50%| ≥ this (same 0–1 scale as prices).
# Example: 0.05 means mid must be ≤45% or ≥55% implied — skips pure coin flips.
TRADE_ENTRY_MIN_EDGE_FROM_50=0.00

# --- Edge-aware entry (fee-adjusted mispricing vs your fair value) ---
# Set TRADE_USE_EDGE_STRATEGY=true and TRADE_FAIR_YES_PROB=0.0–1.0 to buy YES only when
# (fair − YES_ask − taker fee) clears TRADE_MIN_NET_EDGE_AFTER_FEES, with extra hurdle near 50%.
# TRADE_USE_EDGE_STRATEGY=false
# TRADE_FAIR_YES_PROB=
TRADE_MIN_NET_EDGE_AFTER_FEES=0.025
TRADE_EDGE_MIDDLE_EXTRA_EDGE=0.01

# `kalshi-bot scan` — optional OpenAI fair value for titles (costs API $; not advice)
# TRADE_LLM_SCREEN_ENABLED=false
# OPENAI_API_KEY=
# TRADE_LLM_MODEL=gpt-4o-mini

# `kalshi-bot llm-trade` — LLM scans markets; code re-checks fee-edge vs your limits
# TRADE_LLM_MAX_MARKETS_PER_RUN=20
# Must be true to actually send orders with: kalshi-bot llm-trade --execute
# TRADE_LLM_AUTO_EXECUTE=false

# Scale caps with account balance (percentage of balance). Enable when you want size to grow with equity.
# TRADE_BALANCE_SIZING_ENABLED=false
# Max notional per trade ≈ balance × this (÷ YES price in cents)
# TRADE_RISK_PCT_OF_BALANCE_PER_TRADE=0.02
# Cap total exposure ≈ balance × this (still bounded by MAX_EXPOSURE_CENTS)
# TRADE_TOTAL_RISK_PCT_OF_BALANCE=0.25

# --- Exit (`kalshi-bot auto-sell`) — implied % OR profit margin; fast IOC-style sells ---
# Kalshi supports time_in_force: immediate_or_cancel (IOC), fill_or_kill, good_till_canceled.
# Default IOC avoids resting exit orders (see API docs). Aggression: sell at best_bid minus N cents.

# Take profit when best YES bid ≥ this implied probability (1–99). Default 72 is a common retail
# band for locking in upside on binary contracts (adjust to your risk tolerance).
TRADE_EXIT_TAKE_PROFIT_MIN_YES_BID_PCT=72

# Optional explicit floor in cents (overrides the % default above when set).
# TRADE_TAKE_PROFIT_MIN_YES_BID_CENTS=85

# Optional profit-based exit: sell when best bid ≥ entry + this many cents.
# TRADE_EXIT_MIN_PROFIT_CENTS_PER_CONTRACT=4

# Manual average entry (cents) for profit math; if unset, estimate from portfolio (rough).
# TRADE_EXIT_ENTRY_REFERENCE_YES_CENTS=
TRADE_EXIT_ESTIMATE_ENTRY_FROM_PORTFOLIO=true

# Set true to only use profit-margin exits (requires TRADE_EXIT_MIN_PROFIT_CENTS_PER_CONTRACT).
TRADE_EXIT_ONLY_PROFIT_MARGIN=false

TRADE_EXIT_SELL_TIME_IN_FORCE=immediate_or_cancel
TRADE_EXIT_SELL_AGGRESSION_CENTS=0

# How often to poll the book for auto-sell (seconds).
TRADE_TAKE_PROFIT_POLL_SECONDS=2

# --- Pacing: avoid spamming signals on the WebSocket stream ---
TRADE_MIN_SECONDS_BETWEEN_ORDERS=45

# -----------------------------------------------------------------------------
# Paper / backtest (simulated fills)
# -----------------------------------------------------------------------------
PAPER_FEE_CENTS_PER_CONTRACT=0
PAPER_SLIPPAGE_CENTS_PER_CONTRACT=0
PAPER_FILL_PROBABILITY=0.85

# -----------------------------------------------------------------------------
# Local dashboard (`kalshi-bot run`)
# -----------------------------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050
DASHBOARD_OPEN_BROWSER=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
STRUCTURED_LOG_PATH=logs/kalshi_bot.jsonl
