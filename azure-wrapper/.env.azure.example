# ─────────────────────────────────────────────────────────────────────────────
# Azure App Service / Container Apps – Application Settings reference
#
# Set these as "Application Settings" in the Azure portal (or via az CLI).
# They are injected as environment variables into the container at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── C# Wrapper: bot command ───────────────────────────────────────────────────
# Which kalshi-bot sub-command to run.
# Options: run | llm-trade | scan | auto-sell | backtest | list-markets | ...
Bot__Command=llm-trade

# Extra CLI flags forwarded verbatim to the Python process.
# Remove --dry-run and add --execute when ready for live trading.
Bot__ExtraArgs=--dry-run --no-web --loop --interval 120

# Port the health-check HTTP listener binds to (leave as 8080 for Azure).
Bot__HealthPort=80

# ── C# Wrapper: Azure Key Vault (optional) ────────────────────────────────────
# If set, the wrapper fetches the listed secrets and injects them as env vars
# into the Python process. Requires the container's Managed Identity to have
# Key Vault Secrets User role on the vault.
Bot__KeyVaultUri=https://YOUR-VAULT.vault.azure.net/
Bot__KeyVaultSecrets=KALSHI-API-KEY-ID,KALSHI-PRIVATE-KEY-PATH,OPENAI-API-KEY

# ── Python bot: Kalshi API credentials ───────────────────────────────────────
# Provide these directly OR pull them from Key Vault (see above).
KALSHI_API_KEY_ID=your-api-key-id
# KALSHI_PRIVATE_KEY_PATH is only used when the key file is on disk.
# For Azure, prefer embedding the PEM content via a Key Vault secret and
# pointing KALSHI_PRIVATE_KEY_PATH at a path written by an init script.
KALSHI_PRIVATE_KEY_PATH=/secrets/kalshi_private_key.pem
KALSHI_ENV=demo

# ── Python bot: safety ────────────────────────────────────────────────────────
LIVE_TRADING=false
DRY_RUN=true

# ── Python bot: risk limits ───────────────────────────────────────────────────
MAX_EXPOSURE_CENTS=50000
MAX_CONTRACTS_PER_MARKET=10
MAX_DAILY_DRAWDOWN_USD=25

# ── Python bot: LLM features ──────────────────────────────────────────────────
TRADE_LLM_SCREEN_ENABLED=true
OPENAI_API_KEY=sk-...
TRADE_LLM_MODEL=gpt-4o-mini
TRADE_LLM_AUTO_EXECUTE=false

# ── Python bot: logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
STRUCTURED_LOG_PATH=/app/logs/kalshi_bot.jsonl

# ── Python bot: dashboard ─────────────────────────────────────────────────────
# Disable the local Flask dashboard in Azure (no browser to open).
DASHBOARD_ENABLED=false
