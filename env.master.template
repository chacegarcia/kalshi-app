# =============================================================================
# KALSHI BOT — MASTER ENVIRONMENT TEMPLATE
# =============================================================================
# 1. Copy this file to `.env` in the project root:
#      cp env.master.template .env
# 2. Fill in the sections below (especially API + limits).
# 3. Never commit `.env` — it is gitignored.
#
# The app loads `.env` automatically (see src/kalshi_bot/config.py).
# =============================================================================

# -----------------------------------------------------------------------------
# API — credentials (demo: https://demo.kalshi.co/ | prod: separate keys)
# -----------------------------------------------------------------------------
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Alternative to PATH: paste PEM body (use \n for newlines in one line if needed)
# KALSHI_PRIVATE_KEY_PEM=

# demo = sandbox API | prod = live (use only when you intend to)
KALSHI_ENV=demo

# -----------------------------------------------------------------------------
# Safety — live orders vs simulation
# -----------------------------------------------------------------------------
# LIVE_TRADING=true  → allows real HTTP orders only if DRY_RUN=false
LIVE_TRADING=false
# DRY_RUN=true       → no orders sent; logs + risk checks still run
DRY_RUN=true

# -----------------------------------------------------------------------------
# Bankroll & bet limits (risk controls)
# -----------------------------------------------------------------------------
# Max total marked exposure across all positions, in **cents** (e.g. 50000 = $500)
MAX_EXPOSURE_CENTS=50000

# Max **contracts** (position + new orders) per single market ticker
MAX_CONTRACTS_PER_MARKET=10
# (alias) MAX_POSITION_CONTRACTS=10

# Max session **drawdown** vs starting balance, in USD (notional risk budget)
MAX_DAILY_DRAWDOWN_USD=25
# (alias) MAX_DAILY_LOSS_USD=25

# Max resting **orders** per market at once
MAX_OPEN_ORDERS_PER_MARKET=3

# Cancel resting orders older than this many seconds
STALE_ORDER_SECONDS=3600

# -----------------------------------------------------------------------------
# Cooldowns & kill switch
# -----------------------------------------------------------------------------
COOLDOWN_AFTER_LOSS_SECONDS=300

# After this many **consecutive** losing closes, apply longer cooldown
LOSS_STREAK_THRESHOLD=3
COOLDOWN_AFTER_LOSS_STREAK_SECONDS=900

# true = block increasing order size after a loss (no martingale sizing)
NO_MARTINGALE=true

# Instant stop: no new orders while true
KILL_SWITCH=false

# -----------------------------------------------------------------------------
# Strategy — sample rule knobs (customize in strategy.py for real research)
# -----------------------------------------------------------------------------
STRATEGY_MARKET_TICKER=

# Only consider buying YES when best ask is at or below this (dollars, e.g. 0.55)
STRATEGY_MAX_YES_ASK_DOLLARS=0.55

# Require at least this bid–ask spread (dollars) before trading
STRATEGY_MIN_SPREAD_DOLLARS=0.00

# Require |mid − 0.5| ≥ this (filters “coin flip” names unless you want them)
STRATEGY_PROBABILITY_GAP=0.00

# Contracts per signal / order size cap for the sample strategy
STRATEGY_ORDER_COUNT=1

# Limit price in **cents** (1–99) for YES bids in the sample
STRATEGY_LIMIT_PRICE_CENTS=50

# Minimum seconds between repeated signals on the same stream
STRATEGY_MIN_SECONDS_BETWEEN_SIGNALS=45

# -----------------------------------------------------------------------------
# Paper trading & backtest stress (not live exchange fees unless you set them)
# -----------------------------------------------------------------------------
PAPER_FEE_CENTS_PER_CONTRACT=0
PAPER_SLIPPAGE_CENTS_PER_CONTRACT=0
PAPER_FILL_PROBABILITY=0.85

# -----------------------------------------------------------------------------
# Local monitor (browser dashboard while `kalshi-bot run` is active)
# -----------------------------------------------------------------------------
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050
DASHBOARD_OPEN_BROWSER=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
STRUCTURED_LOG_PATH=logs/kalshi_bot.jsonl
